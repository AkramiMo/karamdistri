{
  "expo": {
    "name": "AKKA ERP",
    "slug": "akka-erp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "akka-erp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B8860B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akka.erp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "L'application utilise votre position pour la navigation vers les clients.",
        "NSLocationAlwaysUsageDescription": "L'application utilise votre position pour suivre vos tournées."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B8860B"
      },
      "package": "com.akka.erp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permettre à AKKA ERP d'accéder à votre position."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
